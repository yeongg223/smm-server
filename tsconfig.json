{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "src",
    "outDir": "dist",
    "esModuleInterop": true,
    "strict": true,
    "paths": {
      "@prisma/*": ["generated/prisma/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "prisma.config.ts"]
}
